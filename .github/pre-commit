#!/bin/sh
set -e

# --- JS/TS ---
echo "Formatting (Prettier)..."
npm run format -w tmuxy-ui

echo "Linting (ESLint --fix)..."
npm run lint:fix -w tmuxy-ui

# Re-stage any files auto-fixed by lint/format
git add -u packages/tmuxy-ui/src

echo "Linting tests (no skipped tests)..."
npx eslint tests/

echo "Checking ESLint config integrity..."
# Prevent weakening ESLint rules: no-restricted-syntax must ban tmuxQuery/tmuxRun
# in test interaction helpers (pane-ops.js, keyboard.js) and test files.
if ! grep -q "tmuxQuery" eslint.config.mjs; then
  echo "ERROR: eslint.config.mjs must ban tmuxQuery in test files."
  echo "Tests must verify via DOM, not tmux CLI. See docs/TESTS.md."
  exit 1
fi

# Run only the unit tests related to the staged tmuxy-ui changes. `vitest
# related` runs a staged test file directly and any tests that transitively
# import a staged source file, so this stays correct while being much faster
# than the full suite. CI still runs the entire suite, so this is purely a
# local speed-up — a miss here is caught there.
CHANGED_UI=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^packages/tmuxy-ui/src/.*\.(ts|tsx)$' \
  | sed 's#^packages/tmuxy-ui/##' || true)
if [ -n "$CHANGED_UI" ]; then
  echo "Running unit tests related to staged changes..."
  # shellcheck disable=SC2086
  npm test -w tmuxy-ui -- related --run $CHANGED_UI
else
  echo "No staged tmuxy-ui source/test changes — skipping unit tests."
fi

# --- Rust ---
echo "Formatting Rust (cargo fmt)..."
cargo fmt -p tmuxy-core -p tmuxy-server

# Re-stage any files formatted by cargo fmt
git add -u packages/tmuxy-core packages/tmuxy-server

echo "Checking Rust (cargo clippy)..."
mkdir -p packages/tmuxy-ui/dist
cargo clippy -p tmuxy-core -p tmuxy-server
