{
  "name": "tmuxy-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--init",
    "--memory=6g",
    "--shm-size=1g",
    "--pids-limit=50000"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "user",
  "mounts": [
    "source=tmuxy-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=tmuxy-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=tmuxy-cargo-git,target=/usr/local/cargo/git,type=volume",
    // Credentials are NOT mounted from host. Log in once inside the
    // container; named volumes persist auth across rebuilds.
    "source=tmuxy-gh-config,target=/home/user/.config/gh,type=volume",
    "source=tmuxy-claude-config,target=/home/user/.claude,type=volume",
    "source=tmuxy-ssh,target=/home/user/.ssh,type=volume",
    "source=tmuxy-git-config,target=/home/user/.config/git,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/user/.claude",
    "CHROME_CDP_URL": "http://localhost:9222",
    "TMUX_SESSION": "dev",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "GIT_CONFIG_GLOBAL": "/home/user/.config/git/config"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/tmuxy,type=bind,consistency=delegated",
  "workspaceFolder": "/tmuxy",
  "postCreateCommand": "npm install && ln -sf /tmuxy/.devcontainer/.tmuxy.conf ~/.tmuxy.conf && ln -sf /tmuxy/bin/tmuxy-cli ~/.local/bin/tmuxy",
  "postStartCommand": "npm start"
}
