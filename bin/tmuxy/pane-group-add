#!/bin/bash
# Create a new pane in a group
# Args: $1=pane_id $2=pane_width $3=pane_height
#
# If the active pane is already in a group, adds to that group.
# Otherwise creates a new group with the active pane + new pane.

set -euo pipefail
source "$(dirname "$0")/_lib"

PANE_ID="$1"
PANE_WIDTH="$2"
PANE_HEIGHT="$3"

# Check if active pane is already in a group (returns the group's window id)
EXISTING_GROUP_WIN=$(find_group_for_pane "$PANE_ID")

# Compute the new group membership before any tmux mutation so we can pass it
# in a single atomic `break-pane ; set-option ; set-option` command — this
# guarantees the window options are visible by the time the monitor processes
# the WindowAdd event from break-pane.
if [ -n "$EXISTING_GROUP_WIN" ]; then
  CURRENT_PANES=$(parse_group_panes "$EXISTING_GROUP_WIN")
fi

# Create new pane via split-window (separate call — needs to return the pane id)
NEW_PANE_ID=$(_tmux split-window -dP -F '#{pane_id}')

# Break the new pane into its own window AND tag the window type + group panes
# in one tmux command list. set-option `-t $NEW_PANE_ID` targets the pane's
# window, which after break-pane is the freshly created group window.
if [ -n "$EXISTING_GROUP_WIN" ]; then
  GROUP_LIST="$CURRENT_PANES $NEW_PANE_ID"
else
  GROUP_LIST="$PANE_ID $NEW_PANE_ID"
fi
_tmux break-pane -d -s "$NEW_PANE_ID" -n group \; \
  set-option -w -t "$NEW_PANE_ID" @tmuxy-window-type group \; \
  set-option -w -t "$NEW_PANE_ID" @tmuxy-group-panes "$GROUP_LIST"

NEW_WIN_ID=$(pane_window "$NEW_PANE_ID")

if [ -n "$EXISTING_GROUP_WIN" ]; then
  # Propagate the updated membership to every existing group window that
  # mirrors the old membership (so navigation between mirrored panes sees
  # the same group).
  _tmux list-windows -F '#{window_id}|#{@tmuxy-window-type}|#{@tmuxy-group-panes}' \
    | while IFS='|' read -r wid wtype wpanes; do
        if [ "$wtype" != "group" ] || [ "$wid" = "$NEW_WIN_ID" ]; then
          continue
        fi
        if [ "$wpanes" = "$CURRENT_PANES" ]; then
          set_group_panes "$wid" $GROUP_LIST
        fi
      done
fi

# Resize the new window to match the source pane
_tmux resize-window -t "$NEW_PANE_ID" -x "$PANE_WIDTH" -y "$PANE_HEIGHT"

# Auto-switch: swap new pane into visible position
_tmux swap-pane -s "$NEW_PANE_ID" -t "$PANE_ID"

refresh_panes
