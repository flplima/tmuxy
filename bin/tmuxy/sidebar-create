#!/bin/bash
# Create the left sidebar's hidden window running the `tmuxy tree` TUI.
#
# The window is tagged @tmuxy-window-type=sidebar so tmuxy excludes it from the
# tab bar (like floats/groups) while the frontend renders its pane as a left
# drawer. Idempotent: if a sidebar window already exists, its pane id is printed
# and nothing new is created — so the UI can call this freely on every toggle.
#
# Unlike float-create (run from a real pane shell via `tmuxy pane float`), this
# script is invoked by the frontend through control-mode `run-shell`, so its
# body already executes inside a run-shell — the safe context that avoids tmux
# 3.5a control-mode hangs. It therefore calls tmux DIRECTLY rather than wrapping
# each mutation in another run-shell: a nested run-shell runs asynchronously, so
# `split-window -P > tmpfile` would race the `cat tmpfile` that reads the new
# pane id, tagging the wrong (pre-existing) pane as the sidebar. The break+tag
# stays a single atomic command list so @tmuxy-window-type is set before the
# monitor reacts to the WindowAdd event.
#
# Options:
#   --width N    Sidebar width in columns (default 30; mirror SIDEBAR_COLS).

set -euo pipefail
source "$(dirname "$0")/_lib"

WIDTH=30
while [ $# -gt 0 ]; do
  case "$1" in
    --width) WIDTH="$2"; shift 2 ;;
    --) shift; break ;;
    *) break ;;
  esac
done

# Idempotency: reuse an existing sidebar window if one is already present.
EXISTING_WIN=$(_tmux list-windows -F '#{window_id}|#{@tmuxy-window-type}' 2>/dev/null \
  | awk -F'|' '$2 == "sidebar" { print $1 }' | head -1)
if [ -n "$EXISTING_WIN" ]; then
  _tmux list-panes -t "$EXISTING_WIN" -F '#{pane_id}' 2>/dev/null | head -1
  exit 0
fi

# Create the pane running the tree TUI. `-dP -F` prints the new pane id straight
# to stdout (captured synchronously — no run-shell, no temp file, no race).
NEW_PANE_ID=$(_tmux split-window -dP -F '#{pane_id}' 'tmuxy tree')

if [ -z "$NEW_PANE_ID" ]; then
  echo "Error: failed to create sidebar pane" >&2
  exit 1
fi

# Break + tag as one atomic command list: @tmuxy-window-type is set in the same
# list as break-pane, so the window is tagged before the monitor sees WindowAdd.
_tmux break-pane -d -s "$NEW_PANE_ID" -n __sidebar \; \
  set-option -w -t "$NEW_PANE_ID" @tmuxy-window-type sidebar \; \
  set-option -w -t "$NEW_PANE_ID" @tmuxy-float-drawer left \; \
  set-option -w -t "$NEW_PANE_ID" @tmuxy-float-width "$WIDTH"

# Apply width (non-fatal if the pane was killed concurrently).
_tmux resize-pane -t "$NEW_PANE_ID" -x "$WIDTH" 2>/dev/null || true

echo "$NEW_PANE_ID"
