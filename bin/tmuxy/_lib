#!/bin/bash
# Shared helpers for tmuxy shell scripts.
#
# Window typing is sourced from the @tmuxy-window-type window option, with
# values: tab | float | float-backdrop | group. Group membership lives in
# @tmuxy-group-panes (space-separated pane ids). Windows without @tmuxy-window-type
# are foreign — tmuxy ignores them.

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"

# Derive TMUX_SOCKET from TMUX env var if not already set.
# Inside run-shell, TMUX is e.g. "/tmp/tmux-1000/tmuxy-dev,110,9" — extract
# the socket name (basename of the path before the first comma).
if [ -z "${TMUX_SOCKET:-}" ] && [ -n "${TMUX:-}" ]; then
  _path="${TMUX%%,*}"
  TMUX_SOCKET="$(basename "$_path")"
  export TMUX_SOCKET
fi

# Wrap tmux to respect TMUX_SOCKET env var for named server sockets.
# Using -L bypasses the TMUX env var, which returns corrupted list-windows
# results inside run-shell (tmux 3.5a bug).
_tmux() {
  command tmux ${TMUX_SOCKET:+-L "$TMUX_SOCKET"} "$@"
}

# Get the window type set on a window via @tmuxy-window-type.
# Args: $1=window_id (e.g., @5)
# Output: tab|float|float-backdrop|group  (empty if not set / foreign)
window_type() {
  _tmux show-options -wqv -t "$1" @tmuxy-window-type 2>/dev/null
}

# Tag the current window with @tmuxy-window-type.
# Args: $1=window_id  $2=type
set_window_type() {
  _tmux set-option -w -t "$1" @tmuxy-window-type "$2"
}

# Find the group window containing a given pane.
# Args: $1=pane_id (e.g., %4)
# Output: window id of the group (e.g., @5), or empty string.
find_group_for_pane() {
  local pane_id="$1"
  _tmux list-windows -F '#{window_id}|#{@tmuxy-window-type}|#{@tmuxy-group-panes}' \
    | while IFS='|' read -r wid wtype wpanes; do
        if [ "$wtype" != "group" ]; then
          continue
        fi
        for pid in $wpanes; do
          if [ "$pid" = "$pane_id" ]; then
            echo "$wid"
            return
          fi
        done
      done
}

# Read the @tmuxy-group-panes list off a group window.
# Args: $1=window_id of the group
# Output: space-separated pane ids (e.g., %4 %6 %7)
parse_group_panes() {
  _tmux show-options -wqv -t "$1" @tmuxy-group-panes 2>/dev/null
}

# Write the @tmuxy-group-panes list onto a group window.
# Args: $1=window_id  $2..=pane ids
set_group_panes() {
  local wid="$1"
  shift
  local joined="$*"
  _tmux set-option -w -t "$wid" @tmuxy-group-panes "$joined"
}

# Find which pane from a list lives in a visible tab window
# (window_type == "tab"). Used to pick the pane to swap into view
# when navigating within a group.
# Args: paneId1 paneId2 ...
# Output: the pane id in a tab window, or empty string.
find_visible_pane_from_list() {
  local tab_wins
  tab_wins=$(_tmux list-windows -F '#{window_id}|#{@tmuxy-window-type}' \
    | awk -F'|' '$2 == "tab" { print $1 }')
  local pane_list
  pane_list=$(_tmux list-panes -s -F '#{pane_id},#{window_id}')

  for pid in "$@"; do
    local win_id
    win_id=$(echo "$pane_list" | grep "^${pid}," | cut -d',' -f2)
    if echo "$tab_wins" | grep -qx "$win_id"; then
      echo "$pid"
      return
    fi
  done
  echo ""
}

# Get active window ID
active_window() {
  _tmux display-message -p '#{window_id}'
}

# Get a pane's window ID
pane_window() {
  _tmux display-message -t "$1" -p '#{window_id}'
}

# List visible (tab-typed) window IDs, one per line.
list_visible_windows() {
  _tmux list-windows -F '#{window_id}|#{@tmuxy-window-type}' \
    | awk -F'|' '$2 == "tab" { print $1 }'
}

# Force a list-panes refresh (so server pushes new state to clients)
refresh_panes() {
  _tmux list-panes -s -F '#{pane_id},#{pane_index},#{pane_left},#{pane_top},#{pane_width},#{pane_height},#{cursor_x},#{cursor_y},#{pane_active},#{pane_current_command},#{pane_title},#{pane_in_mode},#{copy_cursor_x},#{copy_cursor_y},#{window_id}' > /dev/null 2>&1
}
