{
  "productName": "tmuxy",
  "version": "1.0.0",
  "identifier": "com.tmuxy.app",
  "build": {
    "beforeDevCommand": "npm run dev -w tmuxy-ui",
    "beforeBuildCommand": "npm run build -w tmuxy-ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../tmuxy-ui/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "tmuxy",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../bin/tmuxy-cli",
      "../../bin/tmuxy/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
