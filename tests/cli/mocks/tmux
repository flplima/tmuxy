#!/bin/bash
# Mock tmux binary for CLI tests
# Logs every invocation and returns canned responses

# Log the call as JSON to the temp file
if [ -n "$MOCK_TMUX_LOG" ]; then
  # Build args array as JSON
  args_json="["
  first=true
  for arg in "$@"; do
    if $first; then first=false; else args_json="$args_json,"; fi
    # Escape for JSON: backslash, quote, and the control characters that appear
    # in tmux -F format strings (tabs are the --json field separator).
    escaped="${arg//\\/\\\\}"
    escaped="${escaped//\"/\\\"}"
    escaped="${escaped//$'\t'/\\t}"
    escaped="${escaped//$'\r'/\\r}"
    args_json="$args_json\"$escaped\""
  done
  args_json="$args_json]"
  echo "{\"args\":$args_json}" >> "$MOCK_TMUX_LOG"
fi

# Return configured exit code if set
exit_code="${MOCK_TMUX_EXIT_CODE:-0}"

# Skip the socket flag pair (-L <name> / -S <path>) for response dispatch.
# The raw argv INCLUDING the socket flag was already logged above — the
# run-cli helper asserts its presence — but canned responses key off the
# actual subcommand.
if [ "${1:-}" = "-L" ] || [ "${1:-}" = "-S" ]; then
  shift 2
fi

# Handle stdin for load-buffer
if [ "${1:-}" = "load-buffer" ] && [ "${2:-}" = "-" ]; then
  cat > /dev/null
  exit "$exit_code"
fi

# Return canned responses based on subcommand
case "${1:-}" in
  list-panes)
    if [ -n "${MOCK_TMUX_LIST_PANES:-}" ]; then
      echo "$MOCK_TMUX_LIST_PANES"
    else
      printf '%%0\t@0\t120\t40\tzsh\t1\n'
      printf '%%1\t@0\t120\t40\tvim\t0\n'
    fi
    ;;
  list-windows)
    if [ -n "${MOCK_TMUX_LIST_WINDOWS:-}" ]; then
      echo "$MOCK_TMUX_LIST_WINDOWS"
    else
      printf '@0\t0\tmain\t2\t1\ttab\n'
      printf '@1\t1\teditor\t1\t0\ttab\n'
    fi
    ;;
  split-window)
    echo "${MOCK_TMUX_SPLIT_PANE_ID:-%99}"
    ;;
  capture-pane)
    if [ -n "${MOCK_TMUX_CAPTURE:-}" ]; then
      echo "$MOCK_TMUX_CAPTURE"
    else
      echo "mock captured content"
    fi
    ;;
  run-shell)
    # Just log it, no output needed
    ;;
  break-pane)
    ;;
  *)
    ;;
esac

exit "$exit_code"
