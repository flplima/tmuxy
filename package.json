{
  "name": "tmuxy",
  "version": "1.0.0",
  "private": true,
  "description": "A tmux terminal wrapper - available as Tauri app or web server",
  "workspaces": [
    "packages/tmuxy-ui",
    "packages/tmuxy-demo"
  ],
  "scripts": {
    "devcontainer": "bash bin/devcontainer",
    "devcontainer:build": "bash bin/devcontainer --build",
    "yolo-mode": "bash bin/devcontainer --cmd 'claude --dangerously-skip-permissions'",
    "build": "npm run build -w tmuxy-ui && cargo build --release -p tmuxy-server && cd packages/tauri-app && tauri build",
    "start": "pm2 start ./bin/dev --name tmuxy-dev --interpreter bash --cwd /tmuxy",
    "stop": "pm2 stop tmuxy-dev 2>/dev/null; pm2 stop tmuxy-prod 2>/dev/null; true",
    "logs": "pm2 logs",
    "tauri:dev": "cargo tauri dev --manifest-path packages/tauri-app/Cargo.toml",
    "tauri:build": "./bin/build-tauri",
    "demo": "pm2 stop tmuxy-dev 2>/dev/null; bash bin/kill-port 9000; npm run build -w tmuxy-ui && npm run dev -w tmuxy-demo -- --port 9003 --hostname 0.0.0.0",
    "test": "npm run test -w tmuxy-ui",
    "test:e2e": "jest --runInBand",
    "test:tauri": "NODE_OPTIONS='--experimental-vm-modules' jest --config tests/tauri/jest.config.js",
    "test:cli": "jest --config tests/cli/jest.config.js",
    "lint": "eslint tests/ && npm run lint -w tmuxy-ui",
    "lint:tests": "eslint tests/",
    "format": "prettier --write 'tests/**/*.js' && npm run format -w tmuxy-ui",
    "agents": "bash bin/devcontainer --name agents --cmd 'bash .claude/start.sh'",
    "prepare": "git config core.hooksPath .github"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "eslint-plugin-jest": "^29.15.0",
    "jest": "^29.7.0",
    "playwright": "^1.58.0",
    "pm2": "^6.0.14",
    "sharp": "^0.34.5",
    "webdriverio": "^9.24.0"
  },
  "dependencies": {
    "web-haptics": "^0.0.6"
  }
}
